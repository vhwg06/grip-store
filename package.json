{
  "name": "grip-store-docker",
  "version": "1.2.9-Docker",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prod": "npm run env:prod && npm run build && npm run start",
    "lint": "eslint",
    "env:dev": "bash ./scripts/switch-env.sh dev",
    "env:prod": "bash ./scripts/switch-env.sh prod",
    "pretest:e2e": "bash ./scripts/pre-test.sh",
    "test:e2e": "playwright test",
    "pretest:e2e:ui": "bash ./scripts/pre-test.sh",
    "test:e2e:ui": "playwright test --ui",
    "pretest:e2e:headed": "bash ./scripts/pre-test.sh",
    "test:e2e:headed": "playwright test --headed",
    "pretest:e2e:debug": "bash ./scripts/pre-test.sh",
    "test:e2e:debug": "playwright test --debug",
    "pretest:admin": "bash ./scripts/pre-test.sh",
    "test:admin": "playwright test playwright/specs/admin --project=chromium",
    "pretest:admin:fast": "bash ./scripts/pre-test.sh",
    "test:admin:fast": "PLAYWRIGHT_WORKERS=6 PLAYWRIGHT_SKIP_SETUP=true playwright test playwright/specs/admin --project=chromium",
    "pretest:admin:failed": "bash ./scripts/pre-test.sh",
    "test:admin:failed": "playwright test playwright/specs/admin --project=chromium --last-failed",
    "test:api": "playwright test --project=api",
    "test:setup": "playwright test --project=setup"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bson": "^7.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.29.0",
    "js-cookie": "^3.0.7",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.19.30",
    "@types/node-cron": "^3.0.11",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
